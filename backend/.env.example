# Database — replace with your Supabase connection string (Session mode, port 5432)
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Secrets — generate strong random strings before deploying
JWT_SECRET=change-this-to-a-long-random-string
COOKIE_SECRET=change-this-to-another-long-random-string

# Backend URL
BACKEND_URL=http://localhost:9000

# CORS
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000,http://localhost:3000

NODE_ENV=development
